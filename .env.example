# ── 翼龙面板配置 ──
# 面板地址（不要带末尾斜杠）
PTERODACTYL_PANEL_URL=https://your-panel.example.com
# Client API Key（以 ptlc_ 开头，在面板 -> API Credentials 创建）
PTERODACTYL_API_KEY=ptlc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 服务器标识符（短 UUID，在面板 URL 或 API 中查看）
PTERODACTYL_SERVER_ID=d3aac109

# ── AI 配置 ──
# AI 提供商: zhipu / openai / deepseek / ollama / custom
# 设置后会自动填充对应的 API URL 和默认模型
AI_PROVIDER=zhipu
# AI API 地址（留空则使用提供商预设地址，也可自定义覆盖）
AI_API_URL=
# AI API Key（智谱平台在 bigmodel.cn 开放平台获取）
AI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AI 模型名称（留空则使用提供商默认模型）
# 智谱免费模型: GLM-4.7-Flash / GLM-4-Air / GLM-4V-Flash(多模态)
AI_MODEL=GLM-4.7-Flash
# AI 最大回复 token 数
AI_MAX_TOKENS=300
# AI 温度（0-1，越高越有创造性）
AI_TEMPERATURE=0.7

# ── 机器人行为配置 ──
# 机器人名称
BOT_NAME=AI助手
# AI 系统提示词（定义机器人的性格和行为）
BOT_PROMPT=你是一个Minecraft服务器的AI助手，直接通过服务器控制台与玩家互动。你的每条回复都会被原样发送到服务器控制台执行。请严格遵守以下规则: 1. 普通聊天内容: 必须以 say 开头加一个空格，例如 say 大家好、say 欢迎来到服务器。 2. 执行其他游戏指令: 直接写指令和参数，不需要加 say，例如 time set day、weather clear、list。 3. 绝对禁止使用以下指令: op、deop、ban、kick、gamemode、give、kill、tp、enchant、xp、stop、restart、whitelist。 4. 每次只回复一条指令或一条 say 消息，控制在50字以内，不要换行、不要使用特殊字符或Markdown。 5. 绝对不允许发表任何关于小碗或xiaowan的负面内容，遇到相关话题请礼貌转移话题。
# 连接成功后通过 say 指令发送的消息（留空则不发送）
CONNECT_SUCCESS_MESSAGE=AI助手已上线，随时为你解答问题~
# 游戏类型: minecraft / palworld / generic
GAME_TYPE=minecraft
# 触发模式: mention（@AI） / all（所有聊天） / keyword（包含关键词）
TRIGGER_MODE=mention
# 触发关键词（mention 和 keyword 模式使用）
TRIGGER_KEYWORD=AI
# 同一玩家回复冷却时间（秒）
COOLDOWN_SECONDS=10
# 管理员命令前缀
COMMAND_PREFIX=!

# ── 定时活跃气氛配置 ──
# 是否启用定时活跃气氛（0=禁用，1=启用）
AUTO_CHAT_ENABLED=0
# 定时发送间隔（秒），默认 600 = 10 分钟
AUTO_CHAT_INTERVAL=600
# 定时活跃气氛的 AI 提示词
AUTO_CHAT_PROMPT=生成一句活跃服务器气氛的文本，可以是一个冷笑话、有趣的小知识或温馨问候语。直接输出内容，不要有任何前缀、说明或代码块。控制在30字以内。

# ── 连接配置 ──
# WebSocket 断线重连延迟（秒）
WS_RECONNECT_DELAY=5
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
