# ── 翼龙面板配置 ──
# 面板地址（不要带末尾斜杠）
PTERODACTYL_PANEL_URL=https://your-panel.example.com
# Client API Key（以 ptlc_ 开头，在面板 -> API Credentials 创建）
PTERODACTYL_API_KEY=ptlc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 服务器标识符（短 UUID，在面板 URL 或 API 中查看）
PTERODACTYL_SERVER_ID=d3aac109

# ── AI 配置 ──
# AI 提供商: openai / custom
AI_PROVIDER=openai
# AI API 地址（支持 OpenAI 兼容接口：OpenAI / DeepSeek / Ollama 等）
AI_API_URL=https://api.openai.com/v1/chat/completions
# AI API Key
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AI 模型名称
AI_MODEL=gpt-4o-mini
# AI 最大回复 token 数
AI_MAX_TOKENS=300
# AI 温度（0-1，越高越有创造性）
AI_TEMPERATURE=0.7

# ── 机器人行为配置 ──
# 机器人名称
BOT_NAME=AI助手
# AI 系统提示词（定义机器人的性格和行为）
BOT_PROMPT=你是一个友好的游戏服务器 AI 助手。你通过服务器控制台与玩家互动，回复需要简洁明了。每次回复控制在50字以内。不要使用特殊字符和代码块。
# 触发模式: mention（@AI） / all（所有聊天） / keyword（包含关键词）
TRIGGER_MODE=mention
# 触发关键词（mention 和 keyword 模式使用）
TRIGGER_KEYWORD=AI
# 同一玩家回复冷却时间（秒）
COOLDOWN_SECONDS=10
# 管理员命令前缀
COMMAND_PREFIX=!

# ── 连接配置 ──
# WebSocket 断线重连延迟（秒）
WS_RECONNECT_DELAY=5
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
