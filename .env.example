# ── 翼龙面板配置 ──
# 面板地址（不要带末尾斜杠）
PTERODACTYL_PANEL_URL=https://your-panel.example.com
# Client API Key（以 ptlc_ 开头，在面板 -> API Credentials 创建）
PTERODACTYL_API_KEY=ptlc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 服务器标识符（短 UUID，在面板 URL 或 API 中查看）
PTERODACTYL_SERVER_ID=d3aac109

# ── AI 配置 ──
# AI 提供商: zhipu / openai / deepseek / ollama / custom
# 设置后会自动填充对应的 API URL 和默认模型
AI_PROVIDER=zhipu
# AI API 地址（留空则使用提供商预设地址，也可自定义覆盖）
AI_API_URL=
# AI API Key（智谱平台在 bigmodel.cn 开放平台获取）
AI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AI 模型名称（留空则使用提供商默认模型）
# 智谱免费模型: glm-4-flash / GLM-4-Air / GLM-4V-Flash(多模态)
AI_MODEL=glm-4-flash
# AI 最大回复 token 数
AI_MAX_TOKENS=300
# AI 温度（0-1，越高越有创造性）
AI_TEMPERATURE=0.7

# ── 机器人行为配置 ──
# 机器人名称
BOT_NAME=AI助手
# AI 系统提示词（定义机器人的性格和行为）
BOT_PROMPT=你是一个Minecraft服务器的AI助手，通过游戏内的 say 指令与玩家互动。玩家发送聊天消息后，你的回复会被自动包装成 'say 你的回复' 发送给所有玩家。你只需要生成纯文本回复内容，不需要添加 say 前缀或任何代码块。回复需要简洁友好，每次控制在50字以内，不要使用换行、特殊字符或Markdown格式。
# 连接成功后通过 say 指令发送的消息（留空则不发送）
CONNECT_SUCCESS_MESSAGE=AI助手已上线，随时为你解答问题~
# 游戏类型: minecraft / palworld / generic
GAME_TYPE=minecraft
# 触发模式: mention（@AI） / all（所有聊天） / keyword（包含关键词）
TRIGGER_MODE=mention
# 触发关键词（mention 和 keyword 模式使用）
TRIGGER_KEYWORD=AI
# 同一玩家回复冷却时间（秒）
COOLDOWN_SECONDS=10
# 管理员命令前缀
COMMAND_PREFIX=!

# ── 连接配置 ──
# WebSocket 断线重连延迟（秒）
WS_RECONNECT_DELAY=5
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
